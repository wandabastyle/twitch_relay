{
  "name": "web",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "svelte-kit sync && vp build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "typecheck": "svelte-kit sync && tsc --noEmit -p tsconfig.json",
    "check": "vp check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "verify": "pnpm run check"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vite-plus": "^0.1.20"
  },
  "packageManager": "pnpm@10.33.0"
}
